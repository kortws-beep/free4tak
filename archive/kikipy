# ============================================================
# 봇 상태 파일 헬퍼 (kis10_realtrade.py ↔ assistant.py 공유)
#
# 파일 구조:
# {
#   "paused":      false,       ← 매매 일시 중단 여부
#   "score_enter": 55,          ← 현재 매수 기준 점수
#   "pending_cmd": null,        ← 대기 명령 {"type": "sell", "code": "005930"}
#   "cmd_result":  null,        ← 명령 처리 결과 문자열
#   "last_status": {...}        ← 매매봇이 주기적으로 기록하는 상태
# }
# ============================================================

def read_state() -> dict:
    """bot_state.json을 읽어 반환한다. 파일이 없으면 기본값 반환."""
    try:
        if os.path.exists(BOT_STATE_FILE):
            with open(BOT_STATE_FILE, "r") as f:
                return json.load(f)
    except Exception:
        pass
    return {
        "paused":      False,
        "score_enter": 55,
        "pending_cmd": None,
        "cmd_result":  None,
        "last_status": None,
    }


def write_state(state: dict):
    """bot_state.json에 상태를 저장한다."""
    try:
        with open(BOT_STATE_FILE, "w") as f:
            json.dump(state, f, ensure_ascii=False, indent=2)
    except Exception as e:
        print(f"⚠️ 상태 파일 저장 오류: {e}")


def update_state(**kwargs):
    """bot_state.json을 부분 업데이트한다."""
    state = read_state()
    state.update(kwargs)
    write_state(state)


