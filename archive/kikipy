async def morning_briefing():
    """평일 08:00에 자동 모닝 브리핑을 전송한다."""
    last_briefing_date = None

    while True:
        await asyncio.sleep(30)
        try:
            now      = now_kst()
            today    = now.strftime("%Y-%m-%d")
            now_hhmm = now.strftime("%H%M")

            # 주말 제외 / 08:00~08:05 / 오늘 아직 미전송
            if now.weekday() >= 5:
                continue
            if not ("0800" <= now_hhmm <= "0805"):
                continue
            if last_briefing_date == today:
                continue

            last_briefing_date = today
            ch = bot.get_channel(CHANNEL_ID)
            if ch:
                await ch.send("🌅 **모닝 브리핑 준비 중...**")
                await _send_briefing(ch)
                print(f"✅ 모닝 브리핑 전송 완료 {today}")

        except Exception as e:
            print(f"⚠️ 브리핑 오류: {e}")


async def status_listener():
    """10초마다 bot_state.json을 읽어 손익 변동 시 디스코드에 알림을 전송한다."""
    last_profit = None

    while True:
        await asyncio.sleep(10)
        try:
            state  = read_state()
            status = state.get("last_status")
            if not status:
                continue

            profit = status.get("total_profit", 0)
            if last_profit is not None and abs(profit - last_profit) > 5000:
                ch = bot.get_channel(CHANNEL_ID)
                if ch:
                    diff = profit - last_profit
                    await ch.send(
                        f"💹 손익 변동: {last_profit:+,}원 → {profit:+,}원 ({diff:+,}원)"
                    )
            last_profit = profit

        except Exception:
            pass


