async def cmd_status(ctx):
    """현재 포지션/예수금/손익 현황을 출력한다."""
    state    = read_state()
    status   = state.get("last_status", {})
    pos_rows = get_open_positions_from_db()
    now      = now_kst().strftime("%H:%M:%S")
    paused   = "⏸️ 일시중단" if state.get("paused") else "▶️ 실행중"

    msg = (
        f"📊 **영암9 현황** [{now}]\n"
        f"상태: {paused}\n"
        f"매수기준: {state.get('score_enter', 70)}점\n"
    )
    if status:
        msg += (
            f"💵 예수금: {status.get('cash', 0):,}원\n"
            f"💰 주문가능: {status.get('psbl_cash', 0):,}원\n"
            f"📈 총손익: {status.get('total_profit', 0):+,}원\n"
        )
    if pos_rows:
        msg += "\n**📦 보유종목 (DB 기준)**\n"
        for code, bp, qty, ais, bt in pos_rows:
            msg += f"  {code} | 매수가:{bp:,}원 | {qty}주 | AI:{ais}점\n"
    else:
        msg += "\n보유종목 없음\n"

    await send_long(ctx, msg)


async def cmd_score(ctx, score: int):
    """매수 기준 점수를 변경한다."""
    if not 0 <= score <= 100:
        await ctx.send("❌ 점수는 0~100 사이여야 해요")
        return
    update_state(score_enter=score)
    await ctx.send(f"✅ 매수 기준 점수 변경: **{score}점**\n(다음 루프부터 적용)")


async def cmd_sell(ctx, code: str):
    """특정 종목 즉시 매도 명령을 전달한다. 종목명 입력 시 코드로 자동 변환."""
    # 종목명 입력 시 코드로 변환
    if not code.isdigit():
        state         = read_state()
        code_name_map = state.get("last_status", {}).get("code_name_map", {})
        found = next(
            (c for c, name in code_name_map.items() if code in name or name in code),
            None
        )
        if found:
            await ctx.send(f"🔍 종목명 '{code}' → 코드 **{found}** 로 변환")
            code = found
        else:
            try:
                conn = sqlite3.connect(TRADE_HIST_DB)
                row  = conn.execute("""
                    SELECT code FROM trades
                    WHERE sell_price IS NULL AND stock_name LIKE ?
                    ORDER BY id DESC LIMIT 1
                """, (f"%{code}%",)).fetchone()
                conn.close()
                if row:
                    await ctx.send(f"🔍 종목명 '{code}' → 코드 **{row[0]}** 로 변환")
                    code = row[0]
                else:
                    await ctx.send(f"❌ '{code}' 종목을 찾을 수 없어요\n직접 코드로 입력: !매도 005935")
                    return
            except Exception as e:
                await ctx.send(f"❌ 종목 검색 오류: {e}")
                return

    update_state(pending_cmd={"type": "sell", "code": code})
    await ctx.send(f"📤 매도 명령 전달: **{code}**\n(다음 루프에서 실행)")

    # 최대 60초 대기 후 결과 확인
    for _ in range(12):
        await asyncio.sleep(5)
        state  = read_state()
        result = state.get("cmd_result")
        if result:
            update_state(cmd_result=None)
            await ctx.send(f"✅ 결과: {result}")
            return

    await ctx.send("⚠️ 응답 없음 — kis10_realtrade.py 실행 중인지 확인하세요")


