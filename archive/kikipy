def get_recent_performance(limit: int = 20) -> list:
    """trade_history.db에서 최근 N건의 완료된 매매 이력을 조회한다."""
    try:
        conn = sqlite3.connect(TRADE_HIST_DB)
        rows = conn.execute("""
            SELECT profit_rate, sell_reason, ai_score, code,
                   buy_price, sell_price, buy_time, sell_time
            FROM trades
            WHERE sell_price IS NOT NULL
            ORDER BY id DESC LIMIT ?
        """, (limit,)).fetchall()
        conn.close()
        return rows
    except Exception:
        return []


def get_open_positions_from_db() -> list:
    """trade_history.db에서 미매도 포지션을 조회한다."""
    try:
        conn = sqlite3.connect(TRADE_HIST_DB)
        rows = conn.execute("""
            SELECT code, buy_price, qty, ai_score, buy_time
            FROM trades
            WHERE sell_price IS NULL
            ORDER BY buy_time DESC
        """).fetchall()
        conn.close()
        return rows
    except Exception:
        return []


def get_ai_cache_info() -> tuple:
    """ai_cache.db에서 최근 20건의 분석 결과와 전체 캐시 수를 반환한다."""
    try:
        conn = sqlite3.connect(AI_CACHE_DB)
        rows = conn.execute("""
            SELECT code, score, reason, analyzed_at
            FROM ai_analysis
            ORDER BY analyzed_at DESC LIMIT 20
        """).fetchall()
        total = conn.execute("SELECT COUNT(*) FROM ai_analysis").fetchone()[0]
        conn.close()
        return rows, total
    except Exception:
        return [], 0


