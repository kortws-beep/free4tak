# ============================================================
# sector_monitor 연계 — 실시간 강세 테마 감지
# ============================================================
# sector_monitor accel 캐시 (5분)
# ============================================================
_accel_cache: dict = {}   # code → (accel, ts)
_accel_cache_ts: float = 0.0

def get_accel_score(code: str) -> int:
    """
    stock_momentum DB에서 종목 체결강도 가속도(accel) 조회.
    ★ 분석 결과:
      accel 1~5  → 평균 +16.61% (최적 진입 구간) → +8점
      accel > 5  → 평균 +11.52% (과열 주의)     → +4점
      accel < -1 → 감속 경고                     → -5점
    5분 캐시로 DB 부하 최소화.
    """
    global _accel_cache, _accel_cache_ts
    import time as _t

    # 5분 캐시 갱신
    if _t.time() - _accel_cache_ts > 300:
        try:
            conn = sqlite3.connect(SECTOR_MONITOR_DB, timeout=3)
            conn.execute("PRAGMA query_only = ON")
            rows = conn.execute("""
                SELECT code, accel
                FROM stock_momentum
                WHERE ts >= datetime('now', 'localtime', '-10 minutes')
                  AND accel != 0
                ORDER BY ts DESC
            """).fetchall()
            conn.close()
            # 종목별 최신 accel만 유지
            _accel_cache = {}
            for c, a in rows:
                if c not in _accel_cache:
                    _accel_cache[c] = a
            _accel_cache_ts = _t.time()
        except Exception as e:
            print(f"⚠️ accel 조회 오류: {e}")
            return 0

    accel = _accel_cache.get(code, 0)
    if accel >= 0.05:
        return 8    # 가속 구간 (실데이터 기준)
    elif accel >= 0.02:
        return 4    # 소폭 가속
    elif accel < -0.05:
        return -5   # 감속 경고
    return 0
