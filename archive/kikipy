async def _send_briefing(target):
    """모닝 브리핑을 생성해 target(ctx 또는 채널)으로 전송한다."""
    now    = now_kst()
    state  = read_state()
    status = state.get("last_status", {})

    searches = [
        ("🇺🇸 미국장",   "미국 증시 나스닥 다우 어제 결과"),
        ("💱 환율",      "원달러 환율 오늘"),
        ("🌤️ 날씨",     None),
        ("🌍 해외뉴스",  "트럼프 중동 뉴스 오늘"),
        ("📈 코스피선물", "코스피 선물 오늘 전망"),
    ]

    msg = f"🌅 **[영암9 모닝 브리핑] {now.strftime('%m/%d %H:%M')}**\n"
    msg += "━━━━━━━━━━━━━━━━━━━━\n"

    for label, query in searches:
        if query is None:
            first = "\n" + ai._get_weather_region()
        else:
            result = ai._web_search(query)
            first  = (
                result.split("\n")[0].replace("- ", "")[:80]
                if result != "검색 결과 없음" else "정보 없음"
            )
        msg += f"{label}: {first}\n"

    msg += "━━━━━━━━━━━━━━━━━━━━\n"
    msg += f"🤖 봇: {'⏸️ 일시중단' if state.get('paused') else '▶️ 실행중'} | 기준: {state.get('score_enter', 70)}점\n"
    if status:
        msg += f"💰 주문가능: {status.get('psbl_cash', 0):,}원 | 손익: {status.get('total_profit', 0):+,}원\n"
    msg += "📌 오늘도 좋은 장 되세요! 💪"

    if hasattr(target, "send"):
        await send_long(target, msg)


