class AIAssistant:
    """키키 — 검색·봇 제어·대화를 모두 처리하는 Claude Sonnet 기반 AI 비서."""

    # 기상청 격자 좌표 (지역명: (nx, ny))
    LOCATIONS = {
        "도포면": (57, 74),
        "영암":   (58, 74),
        "목포":   (50, 67),
        "나주":   (56, 77),
        "해남":   (54, 65),
        "광주":   (60, 74),
        "강진":   (56, 68),
        "무안":   (52, 71),
        "운남면": (52, 70),
    }

    # 기상청 코드 매핑
    PTY_CODE = {"0": "없음", "1": "비", "2": "비/눈", "3": "눈", "4": "소나기"}
    SKY_CODE = {"1": "맑음", "3": "구름많음", "4": "흐림"}

    # 구어체 → 검색어 자동 변환 사전
    SEARCH_SHORTCUTS = {
        "미국장":  "미국 증시 나스닥 다우 오늘",
        "미국 장": "미국 증시 나스닥 다우 오늘",
        "나스닥":  "나스닥 오늘 시황",
        "트럼프":  "트럼프 발언 뉴스 오늘",
        "중동":    "중동 상황 뉴스 오늘",
        "환율":    "원달러 환율 오늘",
        "코스피":  "코스피 오늘 시황",
        "코스닥":  "코스닥 오늘 시황",
        "유가":    "국제유가 WTI 오늘",
        "금값":    "금 시세 오늘",
        "반도체":  "반도체 뉴스 오늘",
        "기아":    "기아 타이거즈 경기 결과",
        "삼성":    "삼성전자 뉴스 오늘",
        "선물":    "코스피 선물 오늘",
    }

    def __init__(self):
        self.llm     = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))
        self.history = []

    # ----------------------------------------------------------
    # 날씨 조회 (기상청 초단기실황 API)
    # ----------------------------------------------------------

    def _get_weather_kma(self, nx: int, ny: int) -> str:
        """기상청 초단기실황 API로 특정 격자 좌표의 날씨를 조회한다."""
        try:
            auth_key = os.getenv("KMA_API_KEY", "")
            if not auth_key:
                return "기상청 API 키 없음"

            target = datetime.datetime.now() - datetime.timedelta(minutes=45)
            url    = "https://apihub.kma.go.kr/api/typ02/openApi/VilageFcstInfoService_2.0/getUltraSrtNcst"
            params = {
                "pageNo": "1", "numOfRows": "1000", "dataType": "JSON",
                "base_date": target.strftime("%Y%m%d"),
                "base_time": target.strftime("%H00"),
                "nx": nx, "ny": ny, "authKey": auth_key,
            }
            items = (
                requests.get(url, params=params, timeout=5)
                .json()
                .get("response", {})
                .get("body", {})
                .get("items", {})
                .get("item", [])
            )
            data     = {item["category"]: item["obsrValue"] for item in items}
            pty      = self.PTY_CODE.get(data.get("PTY", "0"), "없음")
            weather  = "비" if pty != "없음" else "맑음"
            return (
                f"{weather} / {data.get('T1H', '?')}°C"
                f" / 습도:{data.get('REH', '?')}%"
                f" / 풍속:{data.get('WSD', '?')}m/s"
            )
        except Exception as e:
            return f"날씨 오류: {e}"

    def _get_weather(self, location: str = "도포면") -> str:
        """지역명으로 날씨를 조회한다."""
        coords = self.LOCATIONS.get(location)
        if not coords:
            return f"{location} 좌표 없음"
        return self._get_weather_kma(*coords)

    def _get_weather_region(self) -> str:
        """주요 지역 5곳의 날씨를 조회해 한 문자열로 반환한다."""
        regions = ["도포면", "목포", "영암", "나주", "해남"]
        return "\n".join(f"  {name}: {self._get_weather(name)}" for name in regions)

    # ----------------------------------------------------------
    # 뉴스 검색
    # ----------------------------------------------------------

    def _web_search(self, query: str) -> str:
        """네이버 뉴스 API로 검색. API 키 없으면 Google News RSS로 폴백."""
        import re
        client_id     = os.getenv("NAVER_CLIENT_ID", "")
        client_secret = os.getenv("NAVER_CLIENT_SECRET", "")

        # 네이버 API 키 없을 때 → Google News RSS 폴백
        if not client_id or not client_secret:
            try:
                encoded = urllib.parse.quote(query)
                url     = f"https://news.google.com/rss/search?q={encoded}&hl=ko&gl=KR&ceid=KR:ko"
                res     = requests.get(url, headers={"User-Agent": "Mozilla/5.0"}, timeout=5)
                root    = ET.fromstring(res.content)
                results = []
                for item in root.findall(".//item")[:5]:
                    title = item.findtext("title", "").strip()
                    desc  = re.sub(r"<[^>]+>", "", item.findtext("description", "")).strip()[:80]
                    if title:
                        results.append(f"- {title} ({desc})")
                return "\n".join(results) if results else "검색 결과 없음"
            except Exception as e:
                return f"검색 실패: {e}"

        # 네이버 뉴스 검색 API
        try:
            encoded = urllib.parse.quote(query)
            url     = f"https://openapi.naver.com/v1/search/news.json?query={encoded}&display=5&sort=date"
            headers = {
                "X-Naver-Client-Id":     client_id,
                "X-Naver-Client-Secret": client_secret,
            }
            items = requests.get(url, headers=headers, timeout=5).json().get("items", [])
            if not items:
                return "검색 결과 없음"
            results = []
            for item in items:
                title = re.sub(r"<[^>]+>", "", item.get("title", "")).strip()
                desc  = re.sub(r"<[^>]+>", "", item.get("description", "")).strip()[:80]
                date  = item.get("pubDate", "")[:16]
                if title:
                    results.append(f"- {title} ({desc}) [{date}]")
            return "\n".join(results)
        except Exception as e:
            print(f"네이버 검색 오류: {e}")
            return "검색 실패"

    # ----------------------------------------------------------
    # 메인 해석 (Claude Sonnet)
    # ----------------------------------------------------------

    def interpret(self, user_msg: str, current_state: dict) -> str:
        """사용자 메시지를 해석해 응답 또는 CMD: 형식의 봇 제어 명령을 반환한다."""
        now = now_kst().strftime("%Y-%m-%d %H:%M")

        # 날씨 질문 감지 → 기상청 API 직접 조회
        weather_keywords = ["날씨", "기온", "온도", "비", "눈", "맑", "흐림"]
        if any(kw in user_msg for kw in weather_keywords):
            detected_loc = next(
                (loc for loc in self.LOCATIONS if loc in user_msg), None
            )
            weather_hint = "\n[날씨 정보]\n" + (
                f"  {detected_loc}: {self._get_weather(detected_loc)}"
                if detected_loc else self._get_weather_region()
            )
        else:
            weather_hint = ""

        # 검색 키워드 힌트
        search_hint = weather_hint
        for k, v in self.SEARCH_SHORTCUTS.items():
            if k in user_msg:
                search_hint += f"\n[검색 힌트] '{k}' → search_news('{v}') 로 검색하세요"
                break

        system = f"""너의 이름은 키키야. 자유롭게 뭐든 답해주는 만능 AI 비서야.
오늘: {now}
봇 상태: {'일시중단' if current_state.get('paused') else '실행중'} / 기준점수: {current_state.get('score_enter', 70)}점
{search_hint}

[규칙]
- 뭐든 물어보면 무조건 답해줘. 역할 제한 없어.
- 최신 정보가 필요하면 반드시 search_news 툴로 검색해줘.
- 한국어로 3줄 이내 간결하게 답해줘.
- 봇 제어 요청이면 CMD: 형식으로 답해.

[봇 제어 형식]
CMD:!상태 / CMD:!점수기준 숫자 / CMD:!매도 종목코드 / CMD:!분석 종목코드
CMD:!정지 / CMD:!시작 / CMD:!성과 / CMD:!도움말"""

        tools = [{
            "name": "search_news",
            "description": "최신 뉴스 검색. 시장/종목/정치/스포츠 등 모든 최신 정보에 사용.",
            "input_schema": {
                "type": "object",
                "properties": {"query": {"type": "string", "description": "검색 키워드"}},
                "required": ["query"],
            },
        }]

        self.history.append({"role": "user", "content": user_msg})
        messages = self.history[-10:]
        res      = self.llm.messages.create(
            model="claude-sonnet-4-6",
            max_tokens=500,
            system=system,
            tools=tools,
            messages=messages,
        )

        # 툴 호출 루프 (최대 3회)
        for i in range(3):
            if res.stop_reason != "tool_use":
                break
            tool_results = []
            for block in res.content:
                if block.type == "tool_use" and block.name == "search_news":
                    query  = block.input.get("query", user_msg)
                    print(f"🔍 키키 검색: {query}")
                    result = self._web_search(query)
                    print(f"📰 결과: {result[:100]}")
                    tool_results.append({
                        "type":        "tool_result",
                        "tool_use_id": block.id,
                        "content":     result,
                    })
            messages = messages + [
                {"role": "assistant", "content": res.content},
                {"role": "user",      "content": tool_results},
            ]
            res = self.llm.messages.create(
                model="claude-sonnet-4-6",
                max_tokens=500,
                system=system,
                tools=tools,
                messages=messages,
            )
            print(f"검색 {i+2}차 stop_reason: {res.stop_reason}")

        reply = "".join(b.text for b in res.content if hasattr(b, "text")).strip()
        self.history.append({"role": "assistant", "content": reply})
        return reply or "응답을 생성하지 못했어요."


