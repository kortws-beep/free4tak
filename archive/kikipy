@bot.event
async def on_message(message):
    """메시지를 수신해 !명령어 또는 자연어로 분기 처리한다."""
    if message.author == bot.user:
        return

    print(f"📨 수신 | 채널:{message.channel.id} | {message.content[:30]}")

    # CHANNEL_ID=0 이면 모든 채널 허용
    if CHANNEL_ID and message.channel.id != CHANNEL_ID:
        return

    content = message.content.strip()
    ctx     = await bot.get_context(message)

    if content.startswith("!"):
        await execute_command(ctx, content)
    elif content:
        async with message.channel.typing():
            state = read_state()
            reply = ai.interpret(content, state)
            if reply.startswith("CMD:"):
                cmd = reply[4:].strip()
                await message.channel.send(f"🤖 AI 비서: `{cmd}` 실행할게요!")
                await execute_command(ctx, cmd)
            else:
                await message.channel.send(f"🤖 {reply}")


