    _master_remove = None
SECTOR_HOT_BONUS   = 8   # 오늘 강세 테마 가산점
SECTOR_CONT_BONUS  = 5   # 3일 연속 강세 테마 추가 가산점
SECTOR_ACCEL_BONUS = 10  # 바통터치 급가속 테마 가산점
_sector_hot_cache  = {}  # {theme_cd: {bonus, nm, ts}}
_sector_cache_time = 0   # 마지막 캐시 갱신 시각


def get_hot_themes(force: bool = False) -> dict:
    """
    sector_monitor DB에서 강세 테마 목록 조회 (5분 캐시).
    반환: {theme_cd: {"bonus": int, "nm": str, "reason": str}}
    """
    global _sector_hot_cache, _sector_cache_time
    import time as _time

    now = _time.time()
    if not force and now - _sector_cache_time < 300:  # 5분 캐시
        return _sector_hot_cache

    if not os.path.exists(SECTOR_MONITOR_DB):
        return {}

    try:
        conn = sqlite3.connect(SECTOR_MONITOR_DB, timeout=5)
        conn.execute("PRAGMA query_only = ON")
        result = {}

        today = datetime.datetime.now().strftime("%Y-%m-%d")
        now_dt = datetime.datetime.now()

        # ① 오늘 강세 테마 (거래대금 상위 + 평균등락 양수)
        rows = conn.execute("""
            SELECT theme_cd, theme_nm,
                   AVG(flu_rt)  as avg_flu,
                   SUM(trde_amt) as total_amt
            FROM sector_flow
            WHERE substr(ts,1,10) = ?
              AND flu_rt > 0.5
            GROUP BY theme_cd
            ORDER BY total_amt DESC
            LIMIT 15
        """, (today,)).fetchall()

        for cd, nm, avg_flu, amt in rows:
            result[cd] = {
                "bonus":  SECTOR_HOT_BONUS,
                "nm":     nm,
                "reason": f"오늘강세({avg_flu:+.1f}%)",
            }

        # ② 3일 연속 강세 → 추가 보너스
        rows2 = conn.execute("""
            SELECT theme_cd, theme_nm,
                   COUNT(DISTINCT substr(ts,1,10)) as days,
                   AVG(flu_rt) as avg_flu
            FROM sector_flow
            WHERE flu_rt > 1.0
            GROUP BY theme_cd
            HAVING days >= 3
        """).fetchall()

        for cd, nm, days, avg_flu in rows2:
            if cd in result:
                result[cd]["bonus"]  += SECTOR_CONT_BONUS
                result[cd]["reason"] += f"+연속{days}일"
            else:
                result[cd] = {
                    "bonus":  SECTOR_CONT_BONUS,
                    "nm":     nm,
                    "reason": f"연속{days}일강세",
                }

        # ③ 바통터치 급가속 테마 → 최우선 보너스
        cutoff = (now_dt - datetime.timedelta(minutes=5)).strftime("%Y-%m-%d %H:%M")
        rows3 = conn.execute("""
            SELECT theme_cd, theme_nm,
                   AVG(flow_rate) as avg_flow
            FROM sector_flow
            WHERE ts >= ?
            GROUP BY theme_cd
            HAVING avg_flow > 30
        """, (cutoff,)).fetchall()

        for cd, nm, avg_flow in rows3:
            if cd in result:
                result[cd]["bonus"]  += SECTOR_ACCEL_BONUS
                result[cd]["reason"] += f"+급가속({avg_flow:.0f}%)"
            else:
                result[cd] = {
                    "bonus":  SECTOR_ACCEL_BONUS,
                    "nm":     nm,
                    "reason": f"급가속({avg_flow:.0f}%)",
                }

        conn.close()
        _sector_hot_cache  = result
        _sector_cache_time = now
        if result:
            print(f"🔥 강세테마 {len(result)}개 감지: "
                  + ", ".join(f"{v['nm']}(+{v['bonus']})" for v in list(result.values())[:3]))
        return result

    except Exception as e:
        print(f"⚠️ sector_monitor 조회 오류: {e}")
        return {}


def get_theme_bonus(code: str, theme_group_map: dict) -> tuple:
    """
    종목코드 → 강세 테마 보너스 점수 반환.
    반환: (bonus_score, reason)
    """
    hot = get_hot_themes()
    if not hot:
        return 0, ""

    # theme_group_map: {theme_cd: [code, ...]}
    for theme_cd, codes in theme_group_map.items():
        if code in codes and theme_cd in hot:
            info = hot[theme_cd]
            return info["bonus"], f"강세테마[{info['nm']}]({info['reason']})"
    return 0, ""


